# Model weights (large binaries — use GitHub Releases, not source control)
*.pth

# Data (large binaries)
/data/

# Artifacts — ignore all except small result CSVs/JSONs
artifacts/*
!artifacts/baseline/
!artifacts/compare_finetuned/
artifacts/**/*.png

# Outputs — ignore all except modal training summary
outputs/*
!outputs/modal_training/
outputs/modal_training/checkpoints/

# Docs (local only)
docs/

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# OS
.DS_Store

# IDE
.vscode/
.idea/
